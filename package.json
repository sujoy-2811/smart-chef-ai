  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "NODE_ENV=production npm start --prefix backend",
    "build": "npm install --prefix backend && npm install --prefix frontend && npm run build --prefix frontend",
    "dev": "concurrently --names \"API,APP\" --prefix-colors \"green,magenta\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:fronted": "npm run dev:frontend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
